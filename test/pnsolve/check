#!/bin/zsh

setopt pipefail
setopt nounset

readonly NORMALIZE_FILTER='del(.searched) | (if has("solutions") then .solutions |= map(del(.clear)) else . end)'
readonly ARTIFACT_FORMAT_VERSION=1

usage() {
  cat <<'USAGE'
Usage:
  test/pnsolve/check
  test/pnsolve/check level1 [level2 ...]
  test/pnsolve/check -level levelN -param PARAM [-show-diff] [-bin PATH] [-out-dir DIR]

Options:
  -level <levelN>   Compare a single case in the specified level.
  -param <PARAM>    Param string for single-case mode.
  -show-diff        Print full jd diff output on DIFF.
  -bin <PATH>       Use an existing pnsolve binary instead of building target/debug/pnsolve.
  -out-dir <DIR>    Persist comparison artifacts for the HTML report.
  -h, --help        Show this help.

Description:
  Compare current pnsolve outputs against baseline JSON files under test/pnsolve/level*/results
  using: jd -set before.json after.json
USAGE
}

validate_level_name() {
  local level="$1"
  [[ "${level}" =~ '^level[0-9]+$' ]]
}

append_diff_param() {
  local level="$1"
  local param="$2"
  if [[ -z "${diff_params[$level]-}" ]]; then
    diff_params[$level]="${param}"
  else
    diff_params[$level]+=$'\n'"${param}"
  fi
}

copy_if_exists() {
  local src="$1"
  local dest="$2"
  if [[ -f "${src}" ]]; then
    cp "${src}" "${dest}"
    return 0
  fi
  return 1
}

artifact_rel_path() {
  local level="$1"
  local param="$2"
  local file_name="$3"
  print -r -- "levels/${level}/cases/${param}/${file_name}"
}

write_case_meta() {
  local level="$1"
  local param="$2"
  local case_status="$3"
  local case_dir="$4"
  local before_rel="$5"
  local after_rel="$6"
  local before_norm_rel="$7"
  local after_norm_rel="$8"
  local diff_rel="$9"
  local stderr_rel="${10}"

  jq -n \
    --arg level "${level}" \
    --arg param "${param}" \
    --arg status "${case_status}" \
    --arg beforePath "${before_rel}" \
    --arg afterPath "${after_rel}" \
    --arg beforeNormalizedPath "${before_norm_rel}" \
    --arg afterNormalizedPath "${after_norm_rel}" \
    --arg diffPath "${diff_rel}" \
    --arg stderrPath "${stderr_rel}" \
    '
      {
        level: $level,
        param: $param,
        status: $status,
        beforePath: (if $beforePath == "" then null else $beforePath end),
        afterPath: (if $afterPath == "" then null else $afterPath end),
        beforeNormalizedPath: (if $beforeNormalizedPath == "" then null else $beforeNormalizedPath end),
        afterNormalizedPath: (if $afterNormalizedPath == "" then null else $afterNormalizedPath end),
        diffPath: (if $diffPath == "" then null else $diffPath end),
        stderrPath: (if $stderrPath == "" then null else $stderrPath end)
      }
    ' > "${case_dir}/meta.json"
}

persist_case_artifacts() {
  local level="$1"
  local param="$2"
  local case_status="$3"
  local before="$4"
  local after="$5"
  local before_cmp="$6"
  local after_cmp="$7"
  local diff_file="$8"
  local stderr_file="$9"

  [[ -z "${ARTIFACT_TMP_ROOT}" ]] && return

  local case_dir="${ARTIFACT_TMP_ROOT}/levels/${level}/cases/${param}"
  local before_rel=""
  local after_rel=""
  local before_norm_rel=""
  local after_norm_rel=""
  local diff_rel=""
  local stderr_rel=""

  mkdir -p "${case_dir}"

  if copy_if_exists "${before}" "${case_dir}/before.raw.json"; then
    before_rel=$(artifact_rel_path "${level}" "${param}" "before.raw.json")
  fi
  if copy_if_exists "${after}" "${case_dir}/after.raw.json"; then
    after_rel=$(artifact_rel_path "${level}" "${param}" "after.raw.json")
  fi
  if copy_if_exists "${before_cmp}" "${case_dir}/before.normalized.json"; then
    before_norm_rel=$(artifact_rel_path "${level}" "${param}" "before.normalized.json")
  fi
  if copy_if_exists "${after_cmp}" "${case_dir}/after.normalized.json"; then
    after_norm_rel=$(artifact_rel_path "${level}" "${param}" "after.normalized.json")
  fi
  if copy_if_exists "${diff_file}" "${case_dir}/diff.jd"; then
    diff_rel=$(artifact_rel_path "${level}" "${param}" "diff.jd")
  fi
  if copy_if_exists "${stderr_file}" "${case_dir}/stderr.txt"; then
    stderr_rel=$(artifact_rel_path "${level}" "${param}" "stderr.txt")
  fi

  write_case_meta \
    "${level}" \
    "${param}" \
    "${case_status}" \
    "${case_dir}" \
    "${before_rel}" \
    "${after_rel}" \
    "${before_norm_rel}" \
    "${after_norm_rel}" \
    "${diff_rel}" \
    "${stderr_rel}"
}

write_manifest() {
  [[ -z "${ARTIFACT_TMP_ROOT}" ]] && return

  jq -n \
    --argjson formatVersion "${ARTIFACT_FORMAT_VERSION}" \
    --arg createdAt "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" \
    --arg repoRoot "${REPO_ROOT}" \
    --arg normalizedFilter "${NORMALIZE_FILTER}" \
    --arg binPath "${PN_SOLVE_BIN}" \
    --argjson singleMode "${SINGLE_MODE}" \
    --argjson checked "${checked}" \
    --argjson diff "${diff_count}" \
    --argjson missingBefore "${missing_before}" \
    --argjson runError "${run_error}" \
    --argjson jdError "${jd_error}" \
    '
      {
        formatVersion: $formatVersion,
        createdAt: $createdAt,
        repoRoot: $repoRoot,
        normalizedFilter: $normalizedFilter,
        executedLevels: $ARGS.positional,
        singleMode: ($singleMode == 1),
        binPath: $binPath,
        summary: {
          checked: $checked,
          diff: $diff,
          missingBefore: $missingBefore,
          runError: $runError,
          jdError: $jdError
        }
      }
    ' \
    --args "${LEVELS[@]}" > "${ARTIFACT_TMP_ROOT}/manifest.json"
}

publish_artifacts() {
  [[ -z "${OUT_DIR_ABS}" ]] && return
  rm -rf "${OUT_DIR_ABS}"
  mkdir -p "${OUT_DIR_ABS:h}"
  cp -R "${ARTIFACT_TMP_ROOT}" "${OUT_DIR_ABS}"
}

resolve_pnsolve_bin() {
  if [[ -n "${BIN_OVERRIDE}" ]]; then
    PN_SOLVE_BIN="${BIN_OVERRIDE:A}"
    if [[ ! -x "${PN_SOLVE_BIN}" ]]; then
      echo "error: pnsolve binary is not executable: ${PN_SOLVE_BIN}" >&2
      exit 2
    fi
    return
  fi

  if ! command -v cargo >/dev/null 2>&1; then
    echo "error: cargo command is required when -bin is not specified" >&2
    exit 2
  fi

  if ! (cd "${REPO_ROOT}" && cargo build -q -p puyo2 --bin pnsolve); then
    echo "error: failed to build pnsolve with cargo" >&2
    exit 2
  fi

  PN_SOLVE_BIN="${REPO_ROOT}/target/debug/pnsolve"
  if [[ ! -x "${PN_SOLVE_BIN}" ]]; then
    echo "error: built pnsolve binary not found: ${PN_SOLVE_BIN}" >&2
    exit 2
  fi
}

run_one_case() {
  local level="$1"
  local param="$2"

  local before="${SCRIPT_DIR}/${level}/results/${param}.json"
  local after="${TMP_ROOT}/${level}/${param}.json"
  local run_err_file="${TMP_ROOT}/errors/${level}/${param}.stderr"
  local diff_file="${TMP_ROOT}/diffs/${level}/${param}.jd"
  local diff_err_file="${TMP_ROOT}/diffs/${level}/${param}.jd.stderr"
  local before_cmp="${TMP_ROOT}/compare/${level}/${param}.before.json"
  local after_cmp="${TMP_ROOT}/compare/${level}/${param}.after.json"
  local norm_err_file="${TMP_ROOT}/errors/${level}/${param}.normalize.stderr"
  local case_status="-"
  local case_diff="-"
  local case_stderr="-"

  ((checked++))

  mkdir -p "${TMP_ROOT}/${level}" "${TMP_ROOT}/diffs/${level}" "${TMP_ROOT}/errors/${level}" "${TMP_ROOT}/compare/${level}"

  if [[ ! -f "${before}" ]]; then
    echo "BEFORE_MISSING ${level} ${param}"
    ((missing_before++))
    case_status="BEFORE_MISSING"
  else
    if ! (
      cd "${REPO_ROOT}" && \
      "${PN_SOLVE_BIN}" -param "${param}" -pretty=false -expand-equivalent-hands >"${after}" 2>"${run_err_file}"
    ); then
      echo "RUN_ERROR ${level} ${param} (stderr: ${run_err_file})"
      ((run_error++))
      case_status="RUN_ERROR"
      case_stderr="${run_err_file}"
    else
      if [[ ! -s "${run_err_file}" ]]; then
        rm -f "${run_err_file}"
      fi

      : > "${norm_err_file}"
      if ! jq "${NORMALIZE_FILTER}" "${before}" > "${before_cmp}" 2>>"${norm_err_file}"; then
        echo "JD_ERROR ${level} ${param} (stderr: ${norm_err_file})"
        ((jd_error++))
        case_status="JD_ERROR"
        case_stderr="${norm_err_file}"
      elif ! jq "${NORMALIZE_FILTER}" "${after}" > "${after_cmp}" 2>>"${norm_err_file}"; then
        echo "JD_ERROR ${level} ${param} (stderr: ${norm_err_file})"
        ((jd_error++))
        case_status="JD_ERROR"
        case_stderr="${norm_err_file}"
      else
        if [[ ! -s "${norm_err_file}" ]]; then
          rm -f "${norm_err_file}"
        fi

        jd -set "${before_cmp}" "${after_cmp}" >"${diff_file}" 2>"${diff_err_file}"
        local jd_status=$?

        if [[ ${jd_status} -eq 0 ]]; then
          rm -f "${diff_file}" "${diff_err_file}"
          case_status="MATCH"
        elif [[ ${jd_status} -eq 1 ]]; then
          echo "DIFF ${level} ${param}"
          ((diff_count++))
          append_diff_param "${level}" "${param}"

          case_status="DIFF"
          case_diff="${diff_file}"
          if [[ -s "${diff_err_file}" ]]; then
            case_stderr="${diff_err_file}"
          else
            rm -f "${diff_err_file}"
          fi

          if [[ ${SHOW_DIFF} -eq 1 ]]; then
            echo "--- DIFF BEGIN ${level} ${param} ---"
            cat "${diff_file}"
            echo "--- DIFF END ${level} ${param} ---"
          fi
        else
          echo "JD_ERROR ${level} ${param} (stderr: ${diff_err_file})"
          ((jd_error++))
          case_status="JD_ERROR"
          case_stderr="${diff_err_file}"
        fi
      fi
    fi
  fi

  LAST_STATUS="${case_status}"
  LAST_BEFORE="${before}"
  LAST_AFTER="${after}"
  LAST_DIFF="${case_diff}"
  LAST_STDERR="${case_stderr}"

  persist_case_artifacts \
    "${level}" \
    "${param}" \
    "${case_status}" \
    "${before}" \
    "${after}" \
    "${before_cmp}" \
    "${after_cmp}" \
    "${case_diff}" \
    "${case_stderr}"
}

typeset -a POSITIONAL=()
SINGLE_LEVEL=""
SINGLE_PARAM=""
BIN_OVERRIDE=""
OUT_DIR=""
OUT_DIR_ABS=""
ARTIFACT_TMP_ROOT=""
typeset -i SHOW_DIFF=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    -show-diff)
      SHOW_DIFF=1
      shift
      ;;
    -level)
      if [[ $# -lt 2 ]]; then
        echo "error: -level requires a value" >&2
        usage >&2
        exit 2
      fi
      SINGLE_LEVEL="$2"
      shift 2
      ;;
    -param)
      if [[ $# -lt 2 ]]; then
        echo "error: -param requires a value" >&2
        usage >&2
        exit 2
      fi
      SINGLE_PARAM="$2"
      shift 2
      ;;
    -bin)
      if [[ $# -lt 2 ]]; then
        echo "error: -bin requires a value" >&2
        usage >&2
        exit 2
      fi
      BIN_OVERRIDE="$2"
      shift 2
      ;;
    -out-dir)
      if [[ $# -lt 2 ]]; then
        echo "error: -out-dir requires a value" >&2
        usage >&2
        exit 2
      fi
      OUT_DIR="$2"
      shift 2
      ;;
    -*)
      echo "error: unknown option: $1" >&2
      usage >&2
      exit 2
      ;;
    *)
      POSITIONAL+=("$1")
      shift
      ;;
  esac
done

if ! command -v jd >/dev/null 2>&1; then
  echo "error: jd command is required" >&2
  exit 2
fi
if ! command -v jq >/dev/null 2>&1; then
  echo "error: jq command is required" >&2
  exit 2
fi

SCRIPT_DIR=${0:A:h}
REPO_ROOT=${SCRIPT_DIR:h:h}

if [[ ! -d "${SCRIPT_DIR}" ]]; then
  echo "error: script directory not found: ${SCRIPT_DIR}" >&2
  exit 2
fi
if [[ ! -f "${REPO_ROOT}/Cargo.toml" ]]; then
  echo "error: repository root not found from script path: ${REPO_ROOT}" >&2
  exit 2
fi

typeset -i SINGLE_MODE=0
if [[ -n "${SINGLE_LEVEL}" || -n "${SINGLE_PARAM}" ]]; then
  if [[ -z "${SINGLE_LEVEL}" || -z "${SINGLE_PARAM}" ]]; then
    echo "error: -level and -param must be specified together" >&2
    usage >&2
    exit 2
  fi
  SINGLE_MODE=1
fi

if [[ ${SINGLE_MODE} -eq 1 && ${#POSITIONAL[@]} -gt 0 ]]; then
  echo "error: positional level arguments cannot be used with -level/-param" >&2
  usage >&2
  exit 2
fi

typeset -a LEVELS=()
if [[ ${SINGLE_MODE} -eq 1 ]]; then
  if ! validate_level_name "${SINGLE_LEVEL}"; then
    echo "error: invalid level format: ${SINGLE_LEVEL} (expected levelN)" >&2
    usage >&2
    exit 2
  fi

  single_list_file="${SCRIPT_DIR}/${SINGLE_LEVEL}/list"
  if [[ ! -f "${single_list_file}" ]]; then
    echo "error: invalid level: ${SINGLE_LEVEL}" >&2
    usage >&2
    exit 2
  fi

  if ! grep -F -x -- "${SINGLE_PARAM}" "${single_list_file}" >/dev/null 2>&1; then
    echo "error: param not found in ${SINGLE_LEVEL}/list: ${SINGLE_PARAM}" >&2
    usage >&2
    exit 2
  fi

  LEVELS=("${SINGLE_LEVEL}")
else
  if [[ ${#POSITIONAL[@]} -eq 0 ]]; then
    typeset -a AUTO_LEVELS=()
    for list_file in "${SCRIPT_DIR}"/level*/list(N); do
      AUTO_LEVELS+=("${list_file:h:t}")
    done
    if [[ ${#AUTO_LEVELS[@]} -gt 0 ]]; then
      while IFS= read -r level; do
        [[ -z "${level}" ]] && continue
        LEVELS+=("${level}")
      done < <(printf "%s\n" "${AUTO_LEVELS[@]}" | LC_ALL=C sort -V)
    fi
    if [[ ${#LEVELS[@]} -eq 0 ]]; then
      echo "error: no level*/list files found under ${SCRIPT_DIR}" >&2
      exit 2
    fi
  else
    for level in "${POSITIONAL[@]}"; do
      if ! validate_level_name "${level}"; then
        echo "error: invalid level format: ${level} (expected levelN)" >&2
        usage >&2
        exit 2
      fi
      if [[ ! -f "${SCRIPT_DIR}/${level}/list" ]]; then
        echo "error: invalid level: ${level}" >&2
        usage >&2
        exit 2
      fi
      LEVELS+=("${level}")
    done
  fi
fi

TMP_ROOT=$(mktemp -d "${TMPDIR:-/tmp}/pnsolve-check.XXXXXX")
if [[ -z "${TMP_ROOT}" || ! -d "${TMP_ROOT}" ]]; then
  echo "error: failed to create temp directory" >&2
  exit 2
fi

if [[ -n "${OUT_DIR}" ]]; then
  OUT_DIR_ABS="${OUT_DIR:A}"
  ARTIFACT_TMP_ROOT="${TMP_ROOT}/artifact"
  mkdir -p "${ARTIFACT_TMP_ROOT}"
fi

typeset -i KEEP_TMP=0
cleanup() {
  if [[ ${KEEP_TMP} -eq 0 ]]; then
    rm -rf "${TMP_ROOT}"
  fi
}
trap cleanup EXIT

resolve_pnsolve_bin

typeset -i checked=0
typeset -i diff_count=0
typeset -i missing_before=0
typeset -i run_error=0
typeset -i jd_error=0
typeset -A diff_params=()

LAST_STATUS="-"
LAST_BEFORE="-"
LAST_AFTER="-"
LAST_DIFF="-"
LAST_STDERR="-"

if [[ ${SINGLE_MODE} -eq 1 ]]; then
  run_one_case "${SINGLE_LEVEL}" "${SINGLE_PARAM}"
  echo "CASE level=${SINGLE_LEVEL} param=${SINGLE_PARAM} status=${LAST_STATUS}"
  echo "before=${LAST_BEFORE}"
  echo "after=${LAST_AFTER}"
  echo "diff=${LAST_DIFF}"
  echo "stderr=${LAST_STDERR}"
else
  for level in "${LEVELS[@]}"; do
    level_dir="${SCRIPT_DIR}/${level}"
    list_file="${level_dir}/list"
    echo "== ${level} =="

    while IFS= read -r param || [[ -n "${param}" ]]; do
      [[ -z "${param}" ]] && continue
      run_one_case "${level}" "${param}"
    done < "${list_file}"
  done
fi

write_manifest
publish_artifacts

echo "checked=${checked} diff=${diff_count} missing_before=${missing_before} run_error=${run_error} jd_error=${jd_error}"

if [[ ${diff_count} -gt 0 ]]; then
  echo "diff params:"
  for level in "${LEVELS[@]}"; do
    if [[ -n "${diff_params[$level]-}" ]]; then
      echo "  ${level}:"
      while IFS= read -r p; do
        [[ -z "${p}" ]] && continue
        echo "    ${p}"
      done <<< "${diff_params[$level]}"
    fi
  done
fi

if [[ $((diff_count + missing_before + run_error + jd_error)) -gt 0 ]]; then
  KEEP_TMP=1
  echo "tmp artifacts: ${TMP_ROOT}"
  exit 1
fi

exit 0
